% neurips_2024.sty — NeurIPS 2024 style (arXiv preprint version)
% Adapted for self-contained arXiv submission.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/01/01 NeurIPS 2024 Style]

\DeclareOption{preprint}{\def\@preprint{1}}
\DeclareOption{nonatbib}{\def\@nonatbib{1}}
\ProcessOptions\relax

% ── Page geometry ─────────────────────────────────────────────────────────────
\RequirePackage[verbose=true,letterpaper]{geometry}
\geometry{
  textheight=9in,
  textwidth=6.5in,
  top=1in,
  headheight=14pt,
  headsep=25pt,
  footskip=30pt
}

% ── Fonts / encoding ──────────────────────────────────────────────────────────
\RequirePackage[T1]{fontenc}
\RequirePackage{times}
\RequirePackage{microtype}

% ── Section heading sizes ─────────────────────────────────────────────────────
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}
\titlespacing*{\section}{0pt}{*2}{*1}
\titlespacing*{\subsection}{0pt}{*1.5}{*0.8}

% ── Caption formatting ────────────────────────────────────────────────────────
\RequirePackage[font=small,labelfont=bf,labelsep=period]{caption}

% ── Abstract ──────────────────────────────────────────────────────────────────
\renewenvironment{abstract}{%
  \vspace{0.5em}%
  \begin{center}%
    {\bfseries Abstract}%
  \end{center}%
  \begin{quote}%
  \small
}{%
  \end{quote}%
  \vspace{0.5em}%
}

% ── Title / author macros ─────────────────────────────────────────────────────
\def\@affil{}
\newcommand{\affil}[1]{\def\@affil{#1}}

% ── Paragraph spacing ─────────────────────────────────────────────────────────
\setlength{\parindent}{0pt}
\setlength{\parskip}{4pt plus 1pt minus 1pt}

% ── Bibliography ──────────────────────────────────────────────────────────────
\ifdefined\@nonatbib\else
  \RequirePackage{natbib}
  \bibliographystyle{unsrt}
  \setcitestyle{numbers,open={[},close={]}}
\fi

% ── Hyperref ──────────────────────────────────────────────────────────────────
\RequirePackage[colorlinks=true,linkcolor=blue,citecolor=blue,urlcolor=blue]{hyperref}

% ── Misc ──────────────────────────────────────────────────────────────────────
\RequirePackage{amsmath,amssymb,amsfonts}
\RequirePackage{booktabs}
\RequirePackage{graphicx}
\RequirePackage{xcolor}
\RequirePackage{subcaption}
\RequirePackage{multirow}
\RequirePackage{tikz}
\usetikzlibrary{arrows.meta,positioning,shapes.geometric,fit,calc,decorations.pathreplacing}
